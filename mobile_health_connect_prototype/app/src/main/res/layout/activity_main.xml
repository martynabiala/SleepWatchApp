<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sleepwatch_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:id="@+id/authContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/sleepwatch_card"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/sleepwatch_card_soft"
                android:padding="10dp"
                android:src="@drawable/sleepwatch_logo"
                android:contentDescription="Logo SleepWatch" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:text="SleepWatch"
                android:textColor="@color/sleepwatch_text"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/authSubtitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:text="Zaloguj sie, aby wejsc do mobilnej wersji SleepWatch."
                android:textColor="@color/sleepwatch_muted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/loginModeButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/sleepwatch_accent"
                    android:text="Logowanie"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/signupModeButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/sleepwatch_accent_soft"
                    android:text="Rejestracja"
                    android:textAllCaps="false"
                    android:textColor="@color/sleepwatch_text" />
            </LinearLayout>

            <EditText
                android:id="@+id/backendUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/sleepwatch_card_soft"
                android:hint="Backend URL, np. http://192.168.x.x:8000"
                android:inputType="textUri"
                android:padding="16dp"
                android:textColor="@color/sleepwatch_text"
                android:textColorHint="@color/sleepwatch_muted" />

            <EditText
                android:id="@+id/loginInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/sleepwatch_card_soft"
                android:hint="Login lub e-mail"
                android:inputType="textEmailAddress"
                android:padding="16dp"
                android:textColor="@color/sleepwatch_text"
                android:textColorHint="@color/sleepwatch_muted" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/sleepwatch_card_soft"
                android:hint="Haslo"
                android:inputType="textPassword"
                android:padding="16dp"
                android:textColor="@color/sleepwatch_text"
                android:textColorHint="@color/sleepwatch_muted" />

            <LinearLayout
                android:id="@+id/signupFieldsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Spinner
                    android:id="@+id/ageGroupSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="8dp" />

                <EditText
                    android:id="@+id/parentEmailInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:hint="E-mail rodzica lub opiekuna (dla konta dziecka)"
                    android:inputType="textEmailAddress"
                    android:padding="16dp"
                    android:textColor="@color/sleepwatch_text"
                    android:textColorHint="@color/sleepwatch_muted" />

                <EditText
                    android:id="@+id/passwordRepeatInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:hint="Powtorz haslo"
                    android:inputType="textPassword"
                    android:padding="16dp"
                    android:textColor="@color/sleepwatch_text"
                    android:textColorHint="@color/sleepwatch_muted" />
            </LinearLayout>

            <Button
                android:id="@+id/authActionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/sleepwatch_accent"
                android:text="Zaloguj"
                android:textAllCaps="false"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/appContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/sleepwatch_card"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="10dp"
                    android:src="@drawable/sleepwatch_logo"
                    android:contentDescription="Logo SleepWatch" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Panel glowny"
                    android:textColor="@color/sleepwatch_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Mobilna wersja SleepWatch prowadzi Cie od logowania, przez wybor zrodla danych, az do synchronizacji snu."
                    android:textColor="@color/sleepwatch_muted" />

                <TextView
                    android:id="@+id/summaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="16dp"
                    android:text="Konto: polaczone"
                    android:textColor="@color/sleepwatch_text" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/sleepwatch_card_soft"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="Dashboard"
                        android:textColor="@color/sleepwatch_text"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/sleepwatch_card_soft"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="Import"
                        android:textColor="@color/sleepwatch_text"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:background="@drawable/sleepwatch_card_soft"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="Profil"
                        android:textColor="@color/sleepwatch_text"
                        android:textStyle="bold" />
                </LinearLayout>

                <Button
                    android:id="@+id/logoutButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:backgroundTint="@color/sleepwatch_accent_soft"
                    android:text="Wyloguj"
                    android:textAllCaps="false"
                    android:textColor="@color/sleepwatch_text" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/sleepwatch_card"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Import danych"
                    android:textColor="@color/sleepwatch_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/sourceSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/sourceHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="16dp"
                    android:textColor="@color/sleepwatch_muted" />

                <Button
                    android:id="@+id/saveSourceButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/sleepwatch_accent_soft"
                    android:text="Zapisz wybor zrodla"
                    android:textAllCaps="false"
                    android:textColor="@color/sleepwatch_text" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/sleepwatch_card"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Synchronizacja"
                    android:textColor="@color/sleepwatch_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/apiTokenInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="16dp"
                    android:text="Token API zapisany automatycznie po zalogowaniu."
                    android:textColor="@color/sleepwatch_muted" />

                <Button
                    android:id="@+id/checkAvailabilityButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/sleepwatch_accent_soft"
                    android:text="Sprawdz dostepnosc"
                    android:textAllCaps="false"
                    android:textColor="@color/sleepwatch_text" />

                <Button
                    android:id="@+id/requestPermissionsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/sleepwatch_accent_soft"
                    android:text="Nadaj uprawnienia"
                    android:textAllCaps="false"
                    android:textColor="@color/sleepwatch_text" />

                <Button
                    android:id="@+id/syncButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/sleepwatch_accent"
                    android:text="Synchronizuj sen"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/sleepwatch_card"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textColor="@color/sleepwatch_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/sleepwatch_card_soft"
                android:padding="16dp"
                android:text="Status: gotowe"
                android:textColor="@color/sleepwatch_text" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>

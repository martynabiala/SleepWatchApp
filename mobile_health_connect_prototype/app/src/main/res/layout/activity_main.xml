<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/sleepwatch_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:id="@+id/authContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/sleepwatch_card"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/sleepwatch_card_soft"
                android:padding="10dp"
                android:src="@drawable/sleepwatch_logo"
                android:contentDescription="Logo SleepWatch" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:text="SleepWatch"
                android:textColor="@color/sleepwatch_text"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/authSubtitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:text="Zaloguj sie, aby wejsc do mobilnej wersji SleepWatch."
                android:textColor="@color/sleepwatch_muted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/loginModeButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/sleepwatch_button_primary"
                    android:elevation="0dp"
                    android:text="Logowanie"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/signupModeButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/sleepwatch_button_secondary"
                    android:elevation="0dp"
                    android:text="Rejestracja"
                    android:textAllCaps="false"
                    android:textColor="@color/sleepwatch_text" />
            </LinearLayout>

            <EditText
                android:id="@+id/backendUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/sleepwatch_input"
                android:hint="Backend URL, np. http://192.168.x.x:8000"
                android:inputType="textUri"
                android:padding="16dp"
                android:textColor="@color/sleepwatch_text"
                android:textColorHint="@color/sleepwatch_muted" />

            <EditText
                android:id="@+id/loginInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/sleepwatch_input"
                android:hint="Login lub e-mail"
                android:inputType="textEmailAddress"
                android:padding="16dp"
                android:textColor="@color/sleepwatch_text"
                android:textColorHint="@color/sleepwatch_muted" />

            <EditText
                android:id="@+id/passwordInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/sleepwatch_input"
                android:hint="Haslo"
                android:inputType="textPassword"
                android:padding="16dp"
                android:textColor="@color/sleepwatch_text"
                android:textColorHint="@color/sleepwatch_muted" />

            <LinearLayout
                android:id="@+id/signupFieldsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <Spinner
                    android:id="@+id/ageGroupSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_input"
                    android:padding="8dp" />

                <EditText
                    android:id="@+id/parentEmailInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_input"
                    android:hint="E-mail rodzica lub opiekuna (dla konta dziecka)"
                    android:inputType="textEmailAddress"
                    android:padding="16dp"
                    android:textColor="@color/sleepwatch_text"
                    android:textColorHint="@color/sleepwatch_muted" />

                <EditText
                    android:id="@+id/passwordRepeatInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_input"
                    android:hint="Powtorz haslo"
                    android:inputType="textPassword"
                    android:padding="16dp"
                    android:textColor="@color/sleepwatch_text"
                    android:textColorHint="@color/sleepwatch_muted" />
            </LinearLayout>

            <Button
                android:id="@+id/authActionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/sleepwatch_button_primary"
                android:elevation="0dp"
                android:text="Zaloguj"
                android:textAllCaps="false"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/appContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/sleepwatch_card"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="10dp"
                    android:src="@drawable/sleepwatch_logo"
                    android:contentDescription="Logo SleepWatch" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Panel glowny"
                    android:textColor="@color/sleepwatch_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Przelaczaj sie miedzy sekcjami jak w normalnej aplikacji i zarzadzaj snem z telefonu."
                    android:textColor="@color/sleepwatch_muted" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/dashboardTabButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/sleepwatch_button_primary"
                        android:elevation="0dp"
                        android:text="Start"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white" />

                    <Button
                        android:id="@+id/historyTabButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/sleepwatch_button_secondary"
                        android:elevation="0dp"
                        android:text="Noce"
                        android:textAllCaps="false"
                        android:textColor="@color/sleepwatch_text" />

                    <Button
                        android:id="@+id/addTabButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/sleepwatch_button_secondary"
                        android:elevation="0dp"
                        android:text="Dodaj"
                        android:textAllCaps="false"
                        android:textColor="@color/sleepwatch_text" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/syncTabButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/sleepwatch_button_secondary"
                        android:elevation="0dp"
                        android:text="Synchronizacja"
                        android:textAllCaps="false"
                        android:textColor="@color/sleepwatch_text" />

                    <Button
                        android:id="@+id/accountTabButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/sleepwatch_button_secondary"
                        android:elevation="0dp"
                        android:text="Konto"
                        android:textAllCaps="false"
                        android:textColor="@color/sleepwatch_text" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/dashboardSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/sleepwatch_card"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dzisiaj"
                    android:textColor="@color/sleepwatch_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Szybki podglad ostatniej nocy i tego, co warto zrobic dalej."
                    android:textColor="@color/sleepwatch_muted" />

                <TextView
                    android:id="@+id/summaryText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="16dp"
                    android:text="Konto: polaczone"
                    android:textColor="@color/sleepwatch_text" />

                <TextView
                    android:id="@+id/dashboardHighlightText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="16dp"
                    android:text="Po zalogowaniu zobaczysz tu krotkie podsumowanie dnia."
                    android:textColor="@color/sleepwatch_muted" />

                <Button
                    android:id="@+id/dashboardSyncButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_button_primary"
                    android:elevation="0dp"
                    android:text="Synchronizuj teraz"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

                <Button
                    android:id="@+id/dashboardHistoryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/sleepwatch_button_secondary"
                    android:elevation="0dp"
                    android:text="Przejdz do nocy"
                    android:textAllCaps="false"
                    android:textColor="@color/sleepwatch_text" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/historySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/sleepwatch_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ostatnie noce"
                    android:textColor="@color/sleepwatch_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Tutaj zobaczysz zapisane noce i szybko odswiezysz historie."
                    android:textColor="@color/sleepwatch_muted" />

                <TextView
                    android:id="@+id/recentNightsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="16dp"
                    android:text="Po zalogowaniu zobaczysz tutaj ostatnie zapisane noce."
                    android:textColor="@color/sleepwatch_text" />

                <Button
                    android:id="@+id/refreshHistoryButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_button_secondary"
                    android:elevation="0dp"
                    android:text="Odswiez historie"
                    android:textAllCaps="false"
                    android:textColor="@color/sleepwatch_text" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/addSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/sleepwatch_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dodaj noc recznie"
                    android:textColor="@color/sleepwatch_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Uzupelnij podstawowe dane i zapisz noc bezposrednio z telefonu."
                    android:textColor="@color/sleepwatch_muted" />

                <EditText
                    android:id="@+id/manualDateInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/sleepwatch_input"
                    android:hint="Data nocy, np. 2026-04-24"
                    android:inputType="date"
                    android:padding="16dp"
                    android:textColor="@color/sleepwatch_text"
                    android:textColorHint="@color/sleepwatch_muted" />

                <EditText
                    android:id="@+id/manualBedtimeInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_input"
                    android:hint="Zasniecie, np. 23:10"
                    android:inputType="datetime"
                    android:padding="16dp"
                    android:textColor="@color/sleepwatch_text"
                    android:textColorHint="@color/sleepwatch_muted" />

                <EditText
                    android:id="@+id/manualWakeTimeInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_input"
                    android:hint="Pobudka, np. 07:05"
                    android:inputType="datetime"
                    android:padding="16dp"
                    android:textColor="@color/sleepwatch_text"
                    android:textColorHint="@color/sleepwatch_muted" />

                <EditText
                    android:id="@+id/manualAwakeningsInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_input"
                    android:hint="Wybudzenia, np. 1"
                    android:inputType="number"
                    android:padding="16dp"
                    android:textColor="@color/sleepwatch_text"
                    android:textColorHint="@color/sleepwatch_muted" />

                <Button
                    android:id="@+id/addManualSleepButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_button_primary"
                    android:elevation="0dp"
                    android:text="Zapisz noc"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/syncSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/sleepwatch_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Synchronizacja"
                    android:textColor="@color/sleepwatch_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Polacz SleepWatch z danymi z telefonu i uruchom synchronizacje snu."
                    android:textColor="@color/sleepwatch_muted" />

                <TextView
                    android:id="@+id/sourceHintText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="16dp"
                    android:textColor="@color/sleepwatch_muted" />

                <TextView
                    android:id="@+id/apiTokenInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="16dp"
                    android:text="Token API zapisany automatycznie po zalogowaniu."
                    android:textColor="@color/sleepwatch_muted" />

                <Button
                    android:id="@+id/checkAvailabilityButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/sleepwatch_button_secondary"
                    android:elevation="0dp"
                    android:text="Sprawdz dostepnosc"
                    android:textAllCaps="false"
                    android:textColor="@color/sleepwatch_text" />

                <Button
                    android:id="@+id/requestPermissionsButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/sleepwatch_button_secondary"
                    android:elevation="0dp"
                    android:text="Nadaj uprawnienia"
                    android:textAllCaps="false"
                    android:textColor="@color/sleepwatch_text" />

                <Button
                    android:id="@+id/syncButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/sleepwatch_button_primary"
                    android:elevation="0dp"
                    android:text="Synchronizuj sen"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="16dp"
                    android:text="Status: gotowe"
                    android:textColor="@color/sleepwatch_text" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/accountSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/sleepwatch_card"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Konto"
                    android:textColor="@color/sleepwatch_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Tutaj sprawdzisz stan polaczenia i w razie potrzeby wylogujesz sie z aplikacji."
                    android:textColor="@color/sleepwatch_muted" />

                <TextView
                    android:id="@+id/accountDetailsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/sleepwatch_card_soft"
                    android:padding="16dp"
                    android:text="Konto: polaczone"
                    android:textColor="@color/sleepwatch_text" />

                <Button
                    android:id="@+id/logoutButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/sleepwatch_button_secondary"
                    android:elevation="0dp"
                    android:text="Wyloguj"
                    android:textAllCaps="false"
                    android:textColor="@color/sleepwatch_text" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>

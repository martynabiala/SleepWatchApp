<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#CFE1F1" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/sleepwatch_border" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/sleepwatch_accent_soft" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1dp"
                android:color="@color/sleepwatch_border" />
        </shape>
    </item>
</selector>
